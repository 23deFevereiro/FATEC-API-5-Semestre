#cloud-config
users:
  - default
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - SSH_PUBLIC_KEY_PLACEHOLDER

ssh_pwauth: false
disable_root: true

# Não rodar apt durante o cloud-init — o install.sh faz isso.
package_update: false
package_upgrade: false
